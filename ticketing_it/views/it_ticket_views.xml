<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_it_ticket_tree" model="ir.ui.view">
        <field name="name">it.ticket.tree</field>
        <field name="model">it.ticket</field>
        <field name="arch" type="xml">
            <list string="IT Tickets" default_order="create_date desc">
                <field name="name" string="Ticket #"/>
                <field name="employee_id"/>
                <field name="ticket_type_id"/>
                <field name="priority" widget="priority"/>
                <field name="state"
                       decoration-success="state=='done'"
                       decoration-danger="state=='rejected'"
                       decoration-warning="state in ['manager_approval','it_approval']"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>
    <!-- GRAPH VIEW -->
    <record id="view_it_ticket_graph" model="ir.ui.view">
        <field name="name">it.ticket.graph</field>
        <field name="model">it.ticket</field>
        <field name="arch" type="xml">
            <graph string="Tickets Analysis" type="bar">
                <field name="state" type="row"/>
                <field name="id" type="measure"/>
            </graph>
        </field>
    </record>
    <!-- DASHBOARD VIEW -->
    <!--    <record id="view_it_ticket_dashboard" model="ir.ui.view">-->
    <!--        <field name="name">it.ticket.dashboard</field>-->
    <!--        <field name="model">it.ticket</field>-->
