<odoo>

    <record id="view_ticket_workflow_config_tree" model="ir.ui.view">
        <field name="name">ticket.workflow.config.tree</field>
        <field name="model">it.ticket.workflow.config</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="ticket_type_id"/>
                <field name="workflow_level"/>
                <field name="category_manager_id"
                                   domain="[('id','in',allowed_category_managers)]"
                                   string="Category Manager"/>
            </list>
        </field>
    </record>

    <record id="action_ticket_workflow_config" model="ir.actions.act_window">
        <field name="name">Ticket Types</field>
        <field name="res_model">it.ticket.workflow.config</field>
        <field name="view_mode">list</field>
    </record>

</odoo>