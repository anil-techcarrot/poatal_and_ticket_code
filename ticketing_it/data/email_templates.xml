<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- 1. Manager Approval -->
        <record id="email_template_manager_approval" model="mail.template">
            <field name="name">IT Ticket - Manager Approval</field>
            <field name="model_id" ref="ticketing_it.model_it_ticket"/>
            <field name="subject">Action Required: IT Ticket Approval</field>
            <field name="email_from">{{ user.company_id.email or 'no-reply@example.com' }}</field>
<!--            <field name="email_to">{{ object.line_manager_id.email }}</field>-->

            <field name="body_html"><![CDATA[
                <div style="font-family: Arial, sans-serif; padding: 20px; max-width: 600px;">
                    <div style="background-color: #2c3e50; padding: 15px; border-radius: 5px;">
                                    <h2 style="color: white; margin: 0;">IT Ticket - Approval Required</h2>
                                </div>
                    <p>Dear <strong><t t-esc="object.line_manager_id.name"/></strong>,</p>

                    <p>An IT ticket requires your approval.</p>

                    <table border="1" cellpadding="6" cellspacing="0" width="100%">
                        <tr style="background-color: #f2f2f2;"><td><b>Ticket</b></td><td><t t-esc="object.name"/></td></tr>
                        <tr><td><b>Subject</b></td><td><t t-esc="object.subject"/></td></tr>
                        <tr style="background-color: #f2f2f2;"><td><b>Employee</b></td><td><t t-esc="object.employee_id.name"/></td></tr>
                        <tr><td><b>Priority</b></td><td><t t-esc="object.priority"/></td></tr>
                        <tr style="background-color: #f2f2f2;"><td><b>Required By</b></td>
                            <td><t t-esc="object.required_date and object.required_date.strftime('%d-%m-%Y') or 'Not specified'"/></td>
                        </tr>
                    </table>

                    <p>Please approve or reject this ticket.</p>
                </div>
            ]]></field>
        </record>
        <record id="email_template_category_manager_approval" model="mail.template">
            <field name="name">IT Ticket - Category Manager Approval</field>
            <field name="model_id" ref="ticketing_it.model_it_ticket"/>
            <field name="subject">Action Required: IT Ticket Approval</field>
            <field name="email_from">{{ user.company_id.email or 'no-reply@example.com' }}</field>
<!--            <field name="email_to">{{ object.category_manager_id.email }}</field>-->

            <field name="body_html"><![CDATA[
                <div style="font-family: Arial, sans-serif; padding: 20px; max-width: 600px;">
                    <div style="background-color: #2c3e50; padding: 15px; border-radius: 5px;">
                                <h2 style="color: white; margin: 0;">IT Ticket - Approval Required</h2>
                            </div>
                    <p>Dear <strong><t t-esc="object.category_manager_id.name"/></strong>,</p>

                    <p>An IT ticket requires your approval.</p>

                    <table border="1" cellpadding="6" cellspacing="0" width="100%">
                        <tr style="background-color: #f2f2f2;"><td><b>Ticket</b></td><td><t t-esc="object.name"/></td></tr>
                        <tr><td><b>Subject</b></td><td><t t-esc="object.subject"/></td></tr>
                        <tr style="background-color: #f2f2f2;"><td><b>Employee</b></td><td><t t-esc="object.employee_id.name"/></td></tr>
                        <tr><td><b>Priority</b></td><td><t t-esc="object.priority"/></td></tr>
                        <tr style="background-color: #f2f2f2;"><td><b>Required By</b></td>
                            <td><t t-esc="object.required_date and object.required_date.strftime('%d-%m-%Y') or 'Not specified'"/></td>
                        </tr>
                    </table>

                    <p>Please approve or reject this ticket.</p>
                </div>
            ]]></field>
        </record>

        <!-- 2. 24hr Reminder -->
        <record id="email_template_manager_reminder_24hr" model="mail.template">
            <field name="name">Manager Reminder</field>
            <field name="model_id" ref="ticketing_it.model_it_ticket"/>
            <field name="subject">Reminder: Ticket Pending</field>
            <field name="email_from">{{ user.company_id.email or 'no-reply@example.com' }}</field>
<!--            <field name="email_to">{{ object.line_manager_id.email }}</field>-->
            <field name="body_html"><![CDATA[
                <div style="font-family: Arial, sans-serif; padding: 20px; max-width: 600px;">
                    <div style="background-color: #e74c3c; padding: 15px; border-radius: 5px; margin-bottom: 20px;">
                                <h2 style="color: white; margin: 0;">Approval Reminder</h2>
                                <p style="color: white; margin: 5px 0 0 0;">This ticket is still waiting for your approval.</p>
                            </div>
                    <p>Dear <strong><t t-esc="object.line_manager_id.name"/></strong>,</p>

                    <p>This ticket is still awaiting your approval.</p>

                    <table border="1" cellpadding="6" width="100%">
                        <tr style="background-color: #f2f2f2;"><td><b>Ticket</b></td><td><t t-esc="object.name"/></td></tr>
                        <tr><td><b>Submitted</b></td>
                            <td><t t-esc="object.submitted_date and object.submitted_date.strftime('%d-%m-%Y %H:%M')"/></td>
                        </tr>
                    </table>

                    <p>Please take action.</p>
                </div>
            ]]></field>
        </record>

        <!-- 3. IT Approval (Already Corrected Earlier) -->
        <record id="email_template_it_approval" model="mail.template">
            <field name="name">IT Ticket - IT Manager Approval Request</field>
            <field name="model_id" ref="ticketing_it.model_it_ticket"/>
            <field name="subject">IT Approval Required</field>

            <field name="email_from"><![CDATA[{{ user.company_id.email or 'no-reply@example.com' }}]]></field>

<!--            <field name="email_to"><![CDATA[{{ object.it_manager_id.email }}]]></field>-->

            <field name="body_html"><![CDATA[
                <div style="font-family: Arial, sans-serif; padding: 20px; max-width: 600px;">

                    <div style="background-color: #2980b9; padding: 15px; border-radius: 5px;">
                        <h2 style="color: white; margin: 0;">IT Manager Approval Required</h2>
                    </div>

                    <p>Dear <strong>
                        <t t-esc="object.it_manager_id.name"/>
                    </strong>,</p>

                    <p>
                        An IT ticket has been approved by the line manager and now requires your approval.
                    </p>

                    <table border="1" cellpadding="6" cellspacing="0" width="100%" style="margin: 15px 0; border-collapse: collapse;">

                        <tr style="background-color: #f2f2f2;">
                            <td><strong>Ticket Number</strong></td>
                            <td><t t-esc="object.name"/></td>
                        </tr>

                        <tr>
                            <td><strong>Subject</strong></td>
                            <td><t t-esc="object.subject"/></td>
                        </tr>

                        <tr style="background-color: #f2f2f2;">
                            <td><strong>Raised By</strong></td>
                            <td><t t-esc="object.employee_id.name"/></td>
                        </tr>

<!--                        <tr>-->
<!--                            <td><strong>Line Manager Approved</strong></td>-->
<!--                            <td>-->
<!--                                <t t-esc="object.line_manager_id.name"/>-->
<!--                                on-->
<!--                                <t t-esc="object.manager_approval_date and object.manager_approval_date.strftime('%d-%m-%Y %H:%M')"/>-->
<!--                            </td>-->
<!--                        </tr>-->

                        <tr>
                            <td><strong>Priority</strong></td>
                            <td><t t-esc="object.priority"/></td>
                        </tr>

                        <tr style="background-color: #f2f2f2;">
                            <td><strong>Required By</strong></td>
                            <td>
                                <t t-esc="object.required_date and object.required_date.strftime('%d-%m-%Y') or 'Not specified'"/>
                            </td>
                        </tr>

                    </table>

                    <p>Please log in to approve or reject this ticket.</p>

                    <br/>

                    <p>Thank you,<br/>
                        <t t-esc="user.company_id.name"/>
                    </p>

                    <p style="color: grey; font-size: 12px;">
                        This is an automated notification. Please do not reply.
                    </p>

                </div>
            ]]></field>

            <field name="auto_delete" eval="True"/>
        </record>
        <!-- 4. Assigned -->
        <record id="email_template_it_assigned" model="mail.template">
            <field name="name">Ticket Assigned</field>
            <field name="model_id" ref="ticketing_it.model_it_ticket"/>
            <field name="subject">Ticket Approved</field>
            <field name="email_from">{{ user.company_id.email or 'no-reply@example.com' }}</field>
<!--            <field name="email_to">{{ object.employee_id.user_id.email }}</field>-->

            <field name="body_html"><![CDATA[
                <div style="font-family: Arial, sans-serif; padding: 20px; max-width: 600px;">
                    <div style="background-color: #27ae60; padding: 15px; border-radius: 5px;">
                                <h2 style="color: white; margin: 0;">Your Ticket Has Been Approved</h2>
                            </div>
                    <p>Dear <strong><t t-esc="object.employee_id.name"/></strong>,</p>

                    <p>Your ticket has been approved and assigned to IT.</p>

                    <table border="1" cellpadding="6">
                        <tr><td><b>Ticket</b></td><td><t t-esc="object.name"/></td></tr>
                        <tr><td><b>Status</b></td><td>Assigned</td></tr>
                    </table>
                </div>
            ]]></field>
        </record>

        <!-- 5. Rejection -->
        <record id="email_template_rejection" model="mail.template">
            <field name="name">Ticket Rejected</field>
            <field name="model_id" ref="ticketing_it.model_it_ticket"/>
            <field name="subject">Ticket Rejected</field>
            <field name="email_from">{{ user.company_id.email or 'no-reply@example.com' }}</field>
<!--            <field name="email_to">{{ object.employee_id.user_id.email }}</field>-->

            <field name="body_html"><![CDATA[
                <div style="font-family: Arial, sans-serif; padding: 20px; max-width: 600px;">
                    <div style="background-color: #c0392b; padding: 15px; border-radius: 5px;">
                                <h2 style="color: white; margin: 0;">Ticket Rejected</h2>
                            </div>
                    <p>Dear <strong><t t-esc="object.employee_id.name"/></strong>,</p>

                    <p>Your ticket has been rejected.</p>

                    <table border="1" cellpadding="6">
                        <tr style="background-color: #f2f2f2;"><td><b>Rejected By</b></td><td><t t-esc="object.rejected_by_id.name"/></td></tr>
                        <tr><td><b>Reason</b></td><td><t t-esc="object.rejection_reason or 'N/A'"/></td></tr>
                    </table>
                </div>
            ]]></field>
        </record>

        <!-- 6. Done -->
        <record id="email_template_done" model="mail.template">
            <field name="name">Ticket Done</field>
            <field name="model_id" ref="ticketing_it.model_it_ticket"/>
            <field name="subject">Ticket Completed</field>
            <field name="email_from">{{ user.company_id.email or 'no-reply@example.com' }}</field>
<!--            <field name="email_to">{{ object.employee_id.user_id.email }}</field>-->

            <field name="body_html"><![CDATA[
                <div style="font-family: Arial, sans-serif; padding: 20px; max-width: 600px;">
                    <div style="background-color: #27ae60; padding: 15px; border-radius: 5px;">
                                <h2 style="color: white; margin: 0;">Your Ticket Is Resolved</h2>
                            </div>
                    <p>Dear <strong><t t-esc="object.employee_id.name"/></strong>,</p>

                    <p>Your ticket has been completed.</p>

                    <table border="1" cellpadding="6">
                        <tr style="background-color: #f2f2f2;"><td><b>Completed On</b></td>
                            <td><t t-esc="object.done_date and object.done_date.strftime('%d-%m-%Y %H:%M')"/></td>
                        </tr>
                    </table>
                </div>
            ]]></field>
        </record>

        <!-- 7. Access End - Assignee -->
        <record id="email_template_access_end_assignee" model="mail.template">
            <field name="name">Access End - Assignee</field>
            <field name="model_id" ref="ticketing_it.model_it_ticket"/>
            <field name="subject">Access Expired</field>
<!--            <field name="email_to">{{ ctx.get('email_to') }}</field>-->

            <field name="body_html"><![CDATA[
                <p>Dear <strong><t t-esc="object.assigned_to_id.name"/></strong>,</p>
                <p>Access for ticket <b><t t-esc="object.name"/></b> has expired.</p>
                <p>Expiry: <t t-esc="object.access_finish_date"/></p>
            ]]></field>
        </record>

        <!-- 8. Access End - Employee -->
        <record id="email_template_access_end_employee" model="mail.template">
            <field name="name">Access End - Employee</field>
            <field name="model_id" ref="ticketing_it.model_it_ticket"/>
            <field name="subject">Access Expired</field>
<!--            <field name="email_to">{{ ctx.get('email_to') }}</field>-->

            <field name="body_html"><![CDATA[
                <p>Dear <strong><t t-esc="object.employee_id.name"/></strong>,</p>
                <p>Your access for ticket <b><t t-esc="object.name"/></b> has expired.</p>
                <p>Expiry: <t t-esc="object.access_finish_date"/></p>
            ]]></field>
        </record>
    </data>
</odoo>
