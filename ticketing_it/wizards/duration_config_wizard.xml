<odoo>
    <record id="view_it_duration_wizard" model="ir.ui.view">
        <field name="name">it.duration.config.wizard.form</field>
        <field name="model">it.duration.config.wizard</field>
        <field name="arch" type="xml">
            <form string="Configure Social Media Duration">
                <group>
                    <field name="duration"/>
                </group>

                <footer>
                    <button name="action_save"
                            string="Save"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>